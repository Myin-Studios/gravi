fun add_empty(a: i32, b: i32): i32;
fun add(a: i32, b: i32): i32
{
    ret a + b;
}

fun div(a: f32, b: f32): f32
{
    ret a / b
    // var aaa: string = "heh!";
}

// no params function
fun no_params() { // "none" return type
    var localVar: string = "Hellowww!";; // added multiple ';' to check the parser
    ; // testing singular ';' to check parser errors
    var booooool: bool = false;
}

var e: bool = true; // unsupported global variable

fun return_string(str: string): string
{
    ret str;
}

fun main()
{
    // div(1, 2); // Items::Call(Expr::Literal(1), Expr::Literal(2))
    
    !PAR var array: f32 = 0.0:3.0::12.0;

    // First debug function:
    show(div(1, div(div(8, 2), 2))); // Items::Call(Expr::Literal(1), Value::Call(Value::Call(8, 2), Expr::Literal(2)))
    show("Woohooo!");
    show(true);
    show(return_string("String from function!")); // this prints numbers, future fix: check the function return type

