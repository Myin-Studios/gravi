fun main()
{
    var a = true;
    var b = false;
    var c = false;

    if !(a || b) || !c
    {
        show("Woohoo!");
    }
    else
    {
        show("Oh... Nooo!");
    }
    
    if !false
    {
        show("Not false!");
    }
    else
    {
        show("Else not true!");
    }

    if b
    {
        show("B!");
    }
    else if a
    {
        show("A!")
    }
    else
    {
        show("C!");
    }
}